  "cases": [
    {
      "id": "nominative",
      "name": "Nominative",
      "kidExplanation": "The subject. Who or what is doing something?",
      "example": "Der Hund schläft.",
      "translation": "The dog sleeps."
    },
    {
      "id": "accusative",
      "name": "Accusative",
      "kidExplanation": "The direct object. What is being seen, eaten, or used?",
      "example": "Ich sehe den Hund.",
      "translation": "I see the dog."
    },
    {
      "id": "dative",
      "name": "Dative",
      "kidExplanation": "Often the receiver or location after certain prepositions.",
      "example": "Ich helfe dem Kind.",
      "translation": "I help the child."
    }
  ],
